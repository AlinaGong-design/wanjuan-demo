import unittest
from src.main import execute


class TestMain(unittest.TestCase):

    def test_execute_success(self):
        """测试正常执行"""
        context = {
            'input': '写一篇关于AI的文章',
            'parameters': {
                'content_type': '文章',
                'style': '正式',
                'length': 500
            }
        }

        result = execute(context)

        self.assertTrue(result['success'])
        self.assertIn('output', result)
