写作助手技能主入口
"""
import json
from typing import Dict, Any, Optional
from .prompts import get_system_prompt, format_user_prompt
from .validator import validate_input
from .writer import WriterEngine


def execute(context: Dict[str, Any]) -> Dict[str, Any]:
    """
    技能主入口函数

    Args:
        context: 包含用户输入和上下文信息的字典
            - input: 用户输入文本
            - parameters: 技能参数
            - conversation_history: 对话历史
            - user_info: 用户信息

    Returns:
        Dict[str, Any]: 执行结果
            - success: 是否成功
            - output: 输出内容
            - metadata: 元数据
    """
    try:
        # 1. 提取输入参数
        user_input = context.get('input', '')
        parameters = context.get('parameters', {})

        # 2. 验证输入
        if not validate_input(user_input, parameters):
            return {
                "success": False,
                "error": "输入参数验证失败",
                "output": "请提供完整的写作要求"
            }

        # 3. 准备提示词
        system_prompt = get_system_prompt()
        user_prompt = format_user_prompt(user_input, parameters)

        # 4. 调用写作引擎
        writer = WriterEngine()
        result = writer.generate(
            system_prompt=system_prompt,
            user_prompt=user_prompt,
            parameters=parameters
        )

        # 5. 返回结果
        return {
            "success": True,
            "output": result['content'],
            "metadata": {
                "word_count": len(result['content']),
                "style": parameters.get('style', '通用'),
                "type": parameters.get('content_type', '文章')
            }
        }

    except Exception as e:
        return {
            "success": False,
            "error": str(e),
            "output": f"写作过程中发生错误: {str(e)}"
        }


def on_install():
    """技能安装时的初始化"""
    print("写作助手技能已安装")


def on_uninstall():
    """技能卸载时的清理"""
    print("写作助手技能已卸载")`
