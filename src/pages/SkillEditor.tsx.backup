          content: `"""
输入验证模块
"""
from typing import Dict, Any


def validate_input(user_input: str, parameters: Dict[str, Any]) -> bool:
    """
    验证用户输入和参数

    Args:
        user_input: 用户输入文本
        parameters: 参数字典

    Returns:
        bool: 验证是否通过
    """
    # 检查输入是否为空
    if not user_input or len(user_input.strip()) == 0:
        return False

    # 检查必需参数
    if 'content_type' in parameters:
        valid_types = ['文章', '报告', '邮件', '通知', '总结']
        if parameters['content_type'] not in valid_types:
            return False

    # 检查字数范围
    if 'length' in parameters:
        length = parameters['length']
        if not isinstance(length, int) or length < 50 or length > 5000:
            return False

    return True


def validate_output(output: str, expected_length: int) -> bool:
    """
    验证输出内容

    Args:
        output: 输出内容
        expected_length: 期望字数

    Returns:
        bool: 是否符合要求
    """
    if not output:
        return False

    actual_length = len(output)
    # 允许±30%的字数偏差
    min_length = expected_length * 0.7
    max_length = expected_length * 1.3

    return min_length <= actual_length <= max_length`
        }
      ]
