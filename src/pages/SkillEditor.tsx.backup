          content: `"""
写作引擎模块
"""
from typing import Dict, Any
import openai


class WriterEngine:
    """写作引擎"""

    def __init__(self):
        self.model = "gpt-4"
        self.temperature = 0.7

    def generate(
        self,
        system_prompt: str,
        user_prompt: str,
        parameters: Dict[str, Any]
    ) -> Dict[str, Any]:
        """
        生成写作内容

        Args:
            system_prompt: 系统提示词
            user_prompt: 用户提示词
            parameters: 生成参数

        Returns:
            Dict[str, Any]: 生成结果
        """
        try:
            # 调用AI模型
            response = openai.ChatCompletion.create(
                model=self.model,
                messages=[
                    {"role": "system", "content": system_prompt},
                    {"role": "user", "content": user_prompt}
                ],
                temperature=self.temperature,
                max_tokens=self._calculate_max_tokens(parameters)
            )

            content = response.choices[0].message.content

            return {
                "content": content,
                "tokens_used": response.usage.total_tokens,
                "model": self.model
            }

        except Exception as e:
            raise Exception(f"生成内容失败: {str(e)}")

    def _calculate_max_tokens(self, parameters: Dict[str, Any]) -> int:
        """根据目标字数计算max_tokens"""
        target_length = parameters.get('length', 500)
        # 中文约1.5个token/字
        return int(target_length * 1.5 * 1.2)  # 留20%余量`
