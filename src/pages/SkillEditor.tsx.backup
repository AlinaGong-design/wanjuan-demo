提示词管理模块
"""
from typing import Dict, Any


def get_system_prompt() -> str:
    """获取系统提示词"""
    return """你是一个专业的写作助手AI，名叫"笔灵"。

你的能力：
- 擅长各类文体写作：文章、报告、邮件、通知、总结等
- 能够适应不同的写作风格：正式、轻松、学术、商务
- 注重内容质量和逻辑性
- 根据字数要求控制篇幅

你的原则：
1. 准确理解用户需求
2. 内容原创且高质量
3. 结构清晰，逻辑严谨
4. 语言得体，符合场景
5. 按要求控制字数

请根据用户的具体需求，创作相应的内容。"""


def format_user_prompt(user_input: str, parameters: Dict[str, Any]) -> str:
    """
    格式化用户提示词

    Args:
        user_input: 用户输入
        parameters: 参数字典

    Returns:
        str: 格式化后的提示词
    """
    content_type = parameters.get('content_type', '文章')
    style = parameters.get('style', '通用')
    length = parameters.get('length', 500)

    prompt = f"""请帮我写一篇{content_type}。

写作要求：
- 主题：{user_input}
- 风格：{style}
- 目标字数：约{length}字

请直接输出内容，无需额外说明。"""

    return prompt


def get_example_prompts() -> list:
    """获取示例提示词"""
    return [
        {
            "title": "商务邮件",
            "input": "给客户发送项目进度更新",
            "parameters": {
                "content_type": "邮件",
                "style": "正式",
                "length": 300
            }
        },
        {
            "title": "技术报告",
            "input": "人工智能在医疗领域的应用",
            "parameters": {
                "content_type": "报告",
                "style": "学术",
                "length": 1000
            }
        },
        {
            "title": "营销文案",
            "input": "新产品发布会邀请函",
            "parameters": {
                "content_type": "通知",
                "style": "轻松",
                "length": 200
            }
        }
    ]`
